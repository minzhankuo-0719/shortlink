# Copy to `.env` for local development. NEVER commit the real .env.
# In production these come from the environment / GCP Secret Manager.

SECRET_KEY=dev-only-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Optional. Defaults to local SQLite if unset.
# DATABASE_URL=postgres://user:pass@localhost:5432/shortlink

# Production only (config.settings.prod). Comma-separated, must include the
# scheme. Add the Cloud Run *.run.app URL, and later the custom domain too.
# CSRF_TRUSTED_ORIGINS=https://shortlink-xxxx-uc.a.run.app

# Production DATABASE_URL when the DB is Cloud SQL, reached through the unix
# socket Cloud Run mounts when deployed with --add-cloudsql-instances (no
# host/port — the socket directory *is* the connection):
# DATABASE_URL=postgres://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE

# Google/Facebook OAuth (Stage 2). Leave blank to keep using plain
# username/password login — that provider's button just won't appear.
# Google: https://console.cloud.google.com/apis/credentials
#   Authorized redirect URI: http://127.0.0.1:8000/accounts/google/login/callback/
# Facebook: https://developers.facebook.com/apps
#   Valid OAuth Redirect URI: http://127.0.0.1:8000/accounts/facebook/login/callback/
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=
